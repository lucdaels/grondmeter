{
  "hosting": {
    "site": "grondmeter-koksijde",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "server.py",
      "data.json",
      "*.bat",
      "*.pdf",
      "*.zip",
      "*.txt",
      "*.md",
      "Photos-*",
      ".git/**",
      ".claude/**",
      "node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  }
}
